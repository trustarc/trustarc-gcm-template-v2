scenarios:
- name: Consent Initialization sets global defaults and gtagSet flags (no cookie)
  code: |-
    const mockData = {
      globalAdStorage: 'denied',
      globalAdUserData: 'denied',
      globalAdPersonalization: 'denied',
      globalAnalyticsStorage: 'denied',
      globalFunctionalityStorage: 'granted',
      globalPersonalizationStorage: 'denied',
      globalSecurityStorage: 'granted',
      waitForUpdate: 500,
      urlPassthrough: true,
      adsDataRedaction: true,
      categoryMapping: [
        { signal: 'ad_storage', categoryId: '3' },
        { signal: 'analytics_storage', categoryId: '2' },
        { signal: 'security_storage', categoryId: 'always' }
      ]
    };

    let capturedDefault;
    const gtagCalls = [];

    mock('copyFromDataLayer', function(key) {
      if (key === 'event') return 'gtm.init_consent';
      return undefined;
    });
    mock('getCookieValues', function() { return []; });
    mock('setDefaultConsentState', function(consent) { capturedDefault = consent; });
    mock('updateConsentState', function() {});
    mock('gtagSet', function(obj) { gtagCalls.push(obj); });

    runCode(mockData);

    assertApi('setDefaultConsentState').wasCalled();
    assertThat(capturedDefault.ad_storage).isEqualTo('denied');
    assertThat(capturedDefault.functionality_storage).isEqualTo('granted');
    assertThat(capturedDefault.security_storage).isEqualTo('granted');
    assertThat(capturedDefault.wait_for_update).isEqualTo(500);
    assertThat(capturedDefault.region).isUndefined();
    assertThat(gtagCalls).hasLength(2);
    assertApi('updateConsentState').wasNotCalled();
    assertApi('gtmOnSuccess').wasCalled();
