- name: Consent updated event maps true/false to granted/denied
  code: |-
    const mockData = {
      globalAdStorage: 'denied',
      globalAdUserData: 'denied',
      globalAdPersonalization: 'denied',
      globalAnalyticsStorage: 'denied',
      globalFunctionalityStorage: 'denied',
      globalPersonalizationStorage: 'denied',
      globalSecurityStorage: 'granted',
      waitForUpdate: 500,
      categoryMapping: [
        { signal: 'ad_storage', categoryId: '3' },
        { signal: 'analytics_storage', categoryId: '2' },
        { signal: 'functionality_storage', categoryId: '1' },
        { signal: 'security_storage', categoryId: 'always' }
      ]
    };

    let capturedUpdate;
    mock('copyFromDataLayer', function(key) {
      if (key === 'event') return 'trustarc-consent-updated';
      if (key === 'consentModel') return 'opt-in';
      if (key === 'consent.ta_category_3') return true;
      if (key === 'consent.ta_category_2') return false;
      if (key === 'consent.ta_category_1') return true;
      return undefined;
    });
    mock('setDefaultConsentState', function() {});
    mock('updateConsentState', function(state) { capturedUpdate = state; });

    runCode(mockData);

    assertApi('setDefaultConsentState').wasNotCalled();
    assertApi('updateConsentState').wasCalled();
    assertThat(capturedUpdate.ad_storage).isEqualTo('granted');
    assertThat(capturedUpdate.analytics_storage).isEqualTo('denied');
    assertThat(capturedUpdate.functionality_storage).isEqualTo('granted');
    assertThat(capturedUpdate.security_storage).isEqualTo('granted');
    assertApi('gtmOnSuccess').wasCalled();
